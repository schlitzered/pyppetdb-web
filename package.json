    "primevue": "^4.3.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.15",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.59.1",
